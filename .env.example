# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FIREBASE_API_KEY: Required by the client-side Firebase Auth initialization.
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"

# Docker Compose / PostgreSQL
APP_PORT=3000
POSTGRES_PORT=5432
POSTGRES_DB=pharmasmart
POSTGRES_USER=pharmasmart
# Replace this value before deploying outside local development.
POSTGRES_PASSWORD=pharmasmart_dev_password

# Used when running the app directly instead of through Docker Compose.
DATABASE_URL=postgresql://pharmasmart:pharmasmart_dev_password@localhost:5432/pharmasmart

# MQTT / ESP32
MQTT_TLS_PORT=8883
MQTT_CERT_CN=localhost
# Use DNS:your-domain.example or IP:203.0.113.10 on the VPS.
MQTT_CERT_SAN=DNS:localhost
MQTT_CERT_DAYS=365
MQTT_REGENERATE_CERTS=false

IOT_PHARMACY_ID=main
IOT_DEVICE_ID=esp32-fridge-01
MQTT_DEVICE_USERNAME=esp32-fridge-01
# Replace both development passwords before exposing port 8883 publicly.
MQTT_DEVICE_PASSWORD=change-device-password
MQTT_INGEST_USERNAME=pharmasmart-ingestion
MQTT_INGEST_PASSWORD=change-ingestion-password
MQTT_INGEST_CLIENT_ID=pharmasmart-ingestion
IOT_WARNING_MARGIN_C=0.5
